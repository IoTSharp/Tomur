{
  "version": 6,
  "cmakeMinimumRequired": {
    "major": 3,
    "minor": 21,
    "patch": 0
  },
  "configurePresets": [
    {
      "name": "base",
      "hidden": true,
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/build/${presetName}",
      "installDir": "${sourceDir}/..",
      "description": "installDir resolves to Tomur/native; CMakeLists.txt install() commands append runtimes/<rid>/native/.",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release",
        "BUILD_SHARED_LIBS": "ON",
        "WHISPER_BUILD_TESTS": "OFF",
        "WHISPER_BUILD_EXAMPLES": "OFF"
      }
    },
    {
      "name": "windows-x64",
      "displayName": "Windows x64 (Release)",
      "inherits": "base",
      "generator": "Visual Studio 18 2026",
      "architecture": {
        "value": "x64",
        "strategy": "set"
      },
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release"
      }
    },
    {
      "name": "linux-x64",
      "displayName": "Linux x64 (Release)",
      "inherits": "base",
      "generator": "Unix Makefiles",
      "cacheVariables": {
        "CMAKE_C_COMPILER": "gcc",
        "CMAKE_CXX_COMPILER": "g++"
      }
    },
    {
      "name": "linux-arm64",
      "displayName": "Linux arm64 (Release)",
      "inherits": "base",
      "generator": "Unix Makefiles",
      "cacheVariables": {
        "CMAKE_C_COMPILER": "aarch64-linux-gnu-gcc",
        "CMAKE_CXX_COMPILER": "aarch64-linux-gnu-g++"
      }
    },
    {
      "name": "debug",
      "displayName": "Debug (current platform)",
      "inherits": "base",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug"
      }
    },
    {
      "name": "windows-x64-cuda13",
      "displayName": "Windows x64 (CUDA 13 Release)",
      "inherits": "windows-x64",
      "cacheVariables": {
        "GGML_CUDA": "ON",
        "WHISPER_NATIVE_BACKEND": "cuda13",
        "CMAKE_CUDA_ARCHITECTURES": "89"
      }
    }
  ],
  "buildPresets": [
    {
      "name": "windows-x64",
      "configurePreset": "windows-x64",
      "configuration": "Release"
    },
    {
      "name": "linux-x64",
      "configurePreset": "linux-x64"
    },
    {
      "name": "linux-arm64",
      "configurePreset": "linux-arm64"
    },
    {
      "name": "debug",
      "configurePreset": "debug"
    },
    {
      "name": "windows-x64-cuda13",
      "configurePreset": "windows-x64-cuda13",
      "configuration": "Release"
    }
  ]
}
