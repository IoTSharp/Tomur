{
  "version": 6,
  "cmakeMinimumRequired": {
    "major": 3,
    "minor": 21,
    "patch": 0
  },
  "configurePresets": [
    {
      "name": "base",
      "hidden": true,
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/build/${presetName}",
      "installDir": "${sourceDir}/..",
      "description": "Install output resolves to Tomur/native; wrapper install() appends runtimes/<rid>/native for final runtime layout.",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release",
        "SD_BUILD_EXAMPLES": "OFF",
        "SD_WEBP": "OFF",
        "SD_WEBM": "OFF",
        "SD_BUILD_SHARED_LIBS": "ON",
        "SD_BUILD_SHARED_GGML_LIB": "OFF",
        "TOMUR_SD_USE_LLAMA_SHARED_GGML": "ON"
      }
    },
    {
      "name": "gpu-base",
      "hidden": true,
      "inherits": "base",
      "cacheVariables": {
        "GGML_NATIVE": "OFF"
      }
    },
    {
      "name": "windows-x64",
      "displayName": "Windows x64 (Release)",
      "inherits": "base",
      "generator": "Visual Studio 18 2026",
      "architecture": {
        "value": "x64",
        "strategy": "set"
      }
    },
    {
      "name": "linux-x64",
      "displayName": "Linux x64 (Release)",
      "inherits": "base",
      "generator": "Unix Makefiles",
      "cacheVariables": {
        "CMAKE_C_COMPILER": "gcc",
        "CMAKE_CXX_COMPILER": "g++"
      }
    },
    {
      "name": "linux-arm64",
      "displayName": "Linux arm64 (Release)",
      "inherits": "base",
      "generator": "Unix Makefiles",
      "cacheVariables": {
        "CMAKE_C_COMPILER": "aarch64-linux-gnu-gcc",
        "CMAKE_CXX_COMPILER": "aarch64-linux-gnu-g++"
      }
    },
    {
      "name": "debug",
      "displayName": "Debug (current platform)",
      "inherits": "base",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug"
      }
    },
    {
      "name": "windows-x64-cuda",
      "displayName": "Windows x64 (CUDA Release)",
      "inherits": ["windows-x64", "gpu-base"],
      "cacheVariables": {
        "SD_CUDA": "ON"
      }
    },
    {
      "name": "windows-x64-vulkan",
      "displayName": "Windows x64 (Vulkan Release)",
      "inherits": ["windows-x64", "gpu-base"],
      "cacheVariables": {
        "SD_VULKAN": "ON"
      }
    },
    {
      "name": "windows-x64-cuda-vulkan",
      "displayName": "Windows x64 (CUDA + Vulkan Release)",
      "inherits": ["windows-x64", "gpu-base"],
      "cacheVariables": {
        "SD_CUDA": "ON",
        "SD_VULKAN": "ON"
      }
    }
  ],
  "buildPresets": [
    {
      "name": "windows-x64",
      "configurePreset": "windows-x64",
      "configuration": "Release"
    },
    {
      "name": "linux-x64",
      "configurePreset": "linux-x64"
    },
    {
      "name": "linux-arm64",
      "configurePreset": "linux-arm64"
    },
    {
      "name": "debug",
      "configurePreset": "debug"
    },
    {
      "name": "windows-x64-cuda",
      "configurePreset": "windows-x64-cuda",
      "configuration": "Release"
    },
    {
      "name": "windows-x64-vulkan",
      "configurePreset": "windows-x64-vulkan",
      "configuration": "Release"
    },
    {
      "name": "windows-x64-cuda-vulkan",
      "configurePreset": "windows-x64-cuda-vulkan",
      "configuration": "Release"
    }
  ]
}
