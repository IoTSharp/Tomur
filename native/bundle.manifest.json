{
  "schema_version": 1,
  "bundle_id": "tomur.native.r8.cuda13",
  "version": "0.8.0-cuda13",
  "runtime_root": "runtimes/{rid}/native",
  "components": [
    {
      "id": "llama",
      "display_name": "llama.cpp",
      "capabilities": [ "chat", "embeddings", "vlm", "gguf" ],
      "source": {
        "type": "git-submodule",
        "path": "native/llama.cpp",
        "url": "https://github.com/ggml-org/llama.cpp.git",
        "license": "MIT"
      },
      "wrapper_path": "native/llama.native",
      "backend": "shared",
      "runtime_path": ".",
      "variants": [
        {
          "id": "cuda13",
          "display_name": "llama.cpp CUDA 13",
          "backend": "cuda",
          "runtime_path": ".",
          "priority": 100,
          "required_backends": [ "ggml-cuda" ],
          "diagnostic": "CUDA is optional; CPU inference remains available when this backend is absent.",
          "actions": [
            "Run tomur native build --rid win-x64 --backend cuda13, then run tomur native prepare."
          ]
        },
        {
          "id": "sycl",
          "display_name": "llama.cpp Intel SYCL",
          "backend": "sycl",
          "runtime_path": ".",
          "priority": 90,
          "required_backends": [ "ggml-sycl" ],
          "diagnostic": "SYCL is the preferred Intel GPU backend when the Intel runtime and driver can enumerate a GPU device.",
          "actions": [
            "Run tomur native build --rid win-x64 --backend sycl, then run tomur native prepare.",
            "Use tomur doctor or /api/runtime/status to inspect device enumeration and CPU fallback."
          ]
        },
        {
          "id": "openvino",
          "display_name": "llama.cpp OpenVINO GPU/NPU",
          "backend": "openvino",
          "runtime_path": ".",
          "priority": 80,
          "required_backends": [ "ggml-openvino" ],
          "diagnostic": "OpenVINO is used for Intel GPU/NPU experiments; NPU selection is opt-in through runtime.accelerator.allow_npu.",
          "actions": [
            "Run tomur native build --rid win-x64 --backend openvino, then run tomur native prepare.",
            "Set runtime.accelerator.openvino_device to GPU, GPU.0 or NPU as needed."
          ]
        },
        {
          "id": "vulkan",
          "display_name": "llama.cpp Vulkan",
          "backend": "vulkan",
          "runtime_path": ".",
          "priority": 70,
          "required_backends": [ "ggml-vulkan" ],
          "diagnostic": "Vulkan is the generic GPU fallback when CUDA, SYCL or OpenVINO are not selected.",
          "actions": [
            "Run tomur native build --rid win-x64 --backend vulkan, then run tomur native prepare.",
            "Install a GPU driver with Vulkan runtime support if devices are not enumerated."
          ]
        },
        {
          "id": "cpu",
          "display_name": "llama.cpp CPU",
          "backend": "cpu",
          "runtime_path": ".",
          "priority": 10,
          "required_backends": [],
          "diagnostic": "CPU is the required fallback backend and remains available when optional accelerator libraries are missing.",
          "actions": [
            "Run tomur native prepare to repair the managed runtime bundle if the CPU backend is missing."
          ]
        }
      ],
      "publisher": true,
      "libraries": [
        { "name": "llama", "required": true },
        { "name": "ggml", "required": true },
        { "name": "ggml-base", "required": true },
        { "name": "ggml-cpu", "required": true },
        { "name": "ggml-cpu-alderlake", "required": false },
        { "name": "ggml-cpu-cannonlake", "required": false },
        { "name": "ggml-cpu-cascadelake", "required": false },
        { "name": "ggml-cpu-haswell", "required": false },
        { "name": "ggml-cpu-icelake", "required": false },
        { "name": "ggml-cpu-sandybridge", "required": false },
        { "name": "ggml-cpu-skylakex", "required": false },
        { "name": "ggml-cpu-sse42", "required": false },
        { "name": "ggml-cpu-x64", "required": false },
        { "name": "ggml-cuda", "required": false },
        { "name": "cublas64_13", "required": false },
        { "name": "cublasLt64_13", "required": false },
        { "name": "cudart64_13", "required": false },
        { "name": "ggml-cann", "required": false },
        { "name": "ggml-metal", "required": false },
        { "name": "ggml-vulkan", "required": false },
        { "name": "ggml-sycl", "required": false },
        { "name": "ggml-openvino", "required": false },
        { "name": "ggml-opencl", "required": false },
        { "name": "tomur-llama-mtmd", "required": false },
        { "name": "tomur-llama-vlm", "required": false }
      ],
      "shared_dependencies": []
    },
    {
      "id": "whisper",
      "display_name": "Whisper",
      "capabilities": [ "asr", "transcription", "translation" ],
      "source": {
        "type": "git-submodule",
        "path": "native/whisper.cpp",
        "url": "https://github.com/ggml-org/whisper.cpp.git",
        "license": "MIT"
      },
      "wrapper_path": "native/whisper.native",
      "backend": "auto",
      "runtime_path": "whisper/cpu",
      "variants": [
        {
          "id": "cuda13",
          "display_name": "Whisper CUDA 13",
          "backend": "cuda",
          "runtime_path": "whisper/cuda13",
          "priority": 100,
          "required_backends": [ "ggml-cuda" ],
          "libraries": [
            { "name": "whisper", "required": true }
          ]
        },
        {
          "id": "cpu",
          "display_name": "Whisper CPU",
          "backend": "cpu",
          "runtime_path": "whisper/cpu",
          "priority": 10,
          "required_backends": [],
          "libraries": [
            { "name": "whisper", "required": true }
          ]
        }
      ],
      "publisher": false,
      "libraries": [
        { "name": "whisper", "required": true }
      ],
      "shared_dependencies": [ "llama", "ggml", "ggml-base", "ggml-cpu" ]
    },
    {
      "id": "stable-diffusion",
      "display_name": "stable-diffusion.cpp",
      "capabilities": [ "image_generation", "gguf" ],
      "source": {
        "type": "git-submodule",
        "path": "native/stable-diffusion.cpp",
        "url": "https://github.com/leejet/stable-diffusion.cpp.git",
        "license": "MIT"
      },
      "wrapper_path": "native/stable-diffusion.native",
      "backend": "auto",
      "runtime_path": "stable-diffusion/cpu",
      "variants": [
        {
          "id": "cuda13",
          "display_name": "stable-diffusion.cpp CUDA 13",
          "backend": "cuda",
          "runtime_path": "stable-diffusion/cuda13",
          "priority": 100,
          "required_backends": [ "ggml-cuda" ],
          "libraries": [
            { "name": "stable-diffusion", "required": true }
          ]
        },
        {
          "id": "cpu",
          "display_name": "stable-diffusion.cpp CPU",
          "backend": "cpu",
          "runtime_path": "stable-diffusion/cpu",
          "priority": 10,
          "required_backends": [],
          "libraries": [
            { "name": "stable-diffusion", "required": true }
          ]
        }
      ],
      "publisher": false,
      "libraries": [
        { "name": "stable-diffusion", "required": true }
      ],
      "shared_dependencies": [ "ggml", "ggml-base", "ggml-cpu" ]
    },
    {
      "id": "ocr",
      "display_name": "PaddleOCR-VL",
      "capabilities": [ "ocr", "document_understanding", "vlm" ],
      "source": {
        "type": "git-submodule",
        "path": "native/paddleocr",
        "url": "https://github.com/PaddlePaddle/PaddleOCR.git",
        "license": "Apache-2.0"
      },
      "wrapper_path": "native/ocr.native",
      "backend": "auto",
      "runtime_path": "ocr/cpu",
      "variants": [
        {
          "id": "cuda13",
          "display_name": "PaddleOCR-VL CUDA 13",
          "backend": "cuda",
          "runtime_path": "ocr/cuda13",
          "priority": 100,
          "required_backends": [ "ggml-cuda" ],
          "libraries": [
            { "name": "tomur-ocr", "required": true },
            { "name": "tomur-mtmd", "required": true }
          ]
        },
        {
          "id": "cpu",
          "display_name": "PaddleOCR-VL CPU",
          "backend": "cpu",
          "runtime_path": "ocr/cpu",
          "priority": 10,
          "required_backends": [],
          "libraries": [
            { "name": "tomur-ocr", "required": true },
            { "name": "tomur-mtmd", "required": true }
          ]
        }
      ],
      "publisher": false,
      "libraries": [
        { "name": "tomur-ocr", "required": true },
        { "name": "tomur-mtmd", "required": true }
      ],
      "shared_dependencies": [ "llama", "ggml", "ggml-base", "ggml-cpu" ]
    },
    {
      "id": "tts",
      "display_name": "llama.cpp GGUF TTS",
      "capabilities": [ "tts", "speech_generation", "gguf" ],
      "source": {
        "type": "git-submodule",
        "path": "native/llama.cpp/tools/tts",
        "url": "https://github.com/ggml-org/llama.cpp.git",
        "license": "MIT"
      },
      "wrapper_path": "native/tts.native",
      "backend": "auto",
      "runtime_path": "tts/cpu",
      "variants": [
        {
          "id": "cuda13",
          "display_name": "llama.cpp GGUF TTS CUDA 13",
          "backend": "cuda",
          "runtime_path": "tts/cuda13",
          "priority": 100,
          "required_backends": [ "ggml-cuda" ],
          "libraries": [
            { "name": "tomur-tts", "required": true }
          ]
        },
        {
          "id": "cpu",
          "display_name": "llama.cpp GGUF TTS CPU",
          "backend": "cpu",
          "runtime_path": "tts/cpu",
          "priority": 10,
          "required_backends": [],
          "libraries": [
            { "name": "tomur-tts", "required": true }
          ]
        }
      ],
      "publisher": false,
      "libraries": [
        { "name": "tomur-tts", "required": true }
      ],
      "shared_dependencies": [ "llama", "ggml", "ggml-base", "ggml-cpu" ]
    }
  ]
}
