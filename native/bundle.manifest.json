{
  "schema_version": 1,
  "bundle_id": "tomur.native.r3",
  "version": "0.3.0-r3",
  "runtime_root": "runtimes/{rid}/native",
  "components": [
    {
      "id": "llama",
      "display_name": "llama.cpp",
      "capabilities": [ "chat", "embeddings", "vlm", "gguf" ],
      "source": {
        "type": "git-submodule",
        "path": "native/llama.cpp",
        "url": "https://github.com/ggml-org/llama.cpp.git",
        "license": "MIT"
      },
      "wrapper_path": "native/llama.native",
      "backend": "shared",
      "runtime_path": ".",
      "publisher": true,
      "libraries": [
        { "name": "llama", "required": true },
        { "name": "ggml", "required": true },
        { "name": "ggml-base", "required": true },
        { "name": "ggml-cpu", "required": true },
        { "name": "ggml-cuda", "required": false },
        { "name": "ggml-cann", "required": false },
        { "name": "ggml-metal", "required": false },
        { "name": "ggml-vulkan", "required": false },
        { "name": "ggml-sycl", "required": false },
        { "name": "ggml-openvino", "required": false },
        { "name": "ggml-opencl", "required": false },
        { "name": "tomur-llama-mtmd", "required": false },
        { "name": "tomur-llama-vlm", "required": false }
      ],
      "shared_dependencies": []
    },
    {
      "id": "whisper",
      "display_name": "Whisper",
      "capabilities": [ "asr", "transcription", "translation" ],
      "source": {
        "type": "git-submodule",
        "path": "native/whisper.cpp",
        "url": "https://github.com/ggml-org/whisper.cpp.git",
        "license": "MIT"
      },
      "wrapper_path": "native/whisper.native",
      "backend": "cpu",
      "runtime_path": "whisper/cpu",
      "publisher": false,
      "libraries": [
        { "name": "whisper", "required": true }
      ],
      "shared_dependencies": [ "llama", "ggml", "ggml-base", "ggml-cpu" ]
    },
    {
      "id": "stable-diffusion",
      "display_name": "stable-diffusion.cpp",
      "capabilities": [ "image_generation", "gguf" ],
      "source": {
        "type": "git-submodule",
        "path": "native/stable-diffusion.cpp",
        "url": "https://github.com/leejet/stable-diffusion.cpp.git",
        "license": "MIT"
      },
      "wrapper_path": "native/stable-diffusion.native",
      "backend": "cpu",
      "runtime_path": "stable-diffusion/cpu",
      "publisher": false,
      "libraries": [
        { "name": "stable-diffusion", "required": true }
      ],
      "shared_dependencies": [ "ggml", "ggml-base", "ggml-cpu" ]
    },
    {
      "id": "ocr",
      "display_name": "PaddleOCR-VL",
      "capabilities": [ "ocr", "document_understanding", "vlm" ],
      "source": {
        "type": "git-submodule",
        "path": "native/paddleocr",
        "url": "https://github.com/PaddlePaddle/PaddleOCR.git",
        "license": "Apache-2.0"
      },
      "wrapper_path": "native/ocr.native",
      "backend": "cpu",
      "runtime_path": "ocr/cpu",
      "publisher": false,
      "libraries": [
        { "name": "tomur-ocr", "required": true },
        { "name": "tomur-mtmd", "required": true }
      ],
      "shared_dependencies": [ "llama", "ggml", "ggml-base", "ggml-cpu" ]
    },
    {
      "id": "tts",
      "display_name": "llama.cpp GGUF TTS",
      "capabilities": [ "tts", "speech_generation", "gguf" ],
      "source": {
        "type": "git-submodule",
        "path": "native/llama.cpp/tools/tts",
        "url": "https://github.com/ggml-org/llama.cpp.git",
        "license": "MIT"
      },
      "wrapper_path": "native/tts.native",
      "backend": "cpu",
      "runtime_path": "tts/cpu",
      "publisher": false,
      "libraries": [
        { "name": "tomur-tts", "required": true }
      ],
      "shared_dependencies": [ "llama", "ggml", "ggml-base", "ggml-cpu" ]
    }
  ]
}
