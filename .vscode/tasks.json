{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Tomur: build app",
      "type": "process",
      "command": "dotnet",
      "args": [
        "build",
        "${workspaceFolder}/app/Tomur.csproj"
      ],
      "problemMatcher": "$msCompile",
      "group": {
        "kind": "build",
        "isDefault": true
      }
    },
    {
      "label": "Tomur: run desktop tray",
      "type": "process",
      "command": "dotnet",
      "args": [
        "run",
        "--project",
        "${workspaceFolder}/app/Tomur.csproj",
        "--",
        "open"
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "problemMatcher": "$msCompile",
      "presentation": {
        "reveal": "always",
        "panel": "dedicated"
      }
    }
  ]
}
